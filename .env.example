# ───────────────────────────────────────────────────────────────
# Frontend (Vite) — copy this file to .env.local and fill in.
# Only VITE_-prefixed vars are exposed to the browser.
# ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ───────────────────────────────────────────────────────────────
# Edge Functions (server-side only — set via `supabase secrets set`,
# NEVER prefixed with VITE_, NEVER committed). Listed for reference.
# Grading is deterministic — no LLM keys required.
# ───────────────────────────────────────────────────────────────
# SUPABASE_SERVICE_ROLE_KEY=...     # auto-provided in deployed functions

# Future seam (deferred): LDAP/SSO provider config goes here when added.
